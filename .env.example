# Database - SQL Server Lokal
# Option 1: SQL Authentication (Format standar Prisma - RECOMMENDED)
DATABASE_URL="sqlserver://sa:YourPassword@127.0.0.1:1433/AgriFlowDB?encrypt=false&trustServerCertificate=true"

# Option 2: Windows Authentication (jika menggunakan Named Instance)
# DATABASE_URL="sqlserver://localhost\\MSSQLSERVER01;database=AgriFlowDB;integratedSecurity=true;trustServerCertificate=true;encrypt=false"

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=30d

# Redis (optional - comment jika tidak pakai)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3002
NODE_ENV=development

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

