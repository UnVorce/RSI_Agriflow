# Database - SQL Server Lokal
# Option 1: Windows Authentication (recommended untuk development)
DATABASE_URL="sqlserver://localhost:1433;database=AgriFlowDB;integratedSecurity=true;trustServerCertificate=true;connection_limit=20"

# Option 2: SQL Authentication
# DATABASE_URL="sqlserver://sa:YourPassword@localhost:1433;database=AgriFlowDB;encrypt=true;trustServerCertificate=true;connection_limit=20"

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=30d

# Redis (optional - comment jika tidak pakai)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3000
NODE_ENV=development

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

